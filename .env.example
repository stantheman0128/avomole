# 複製成 .env 後填真值。.env 已在 .gitignore，切勿 commit 真 secret。

# Postgres（Zeabur）。本機開發用 public host；部署走 Zeabur 內部變數。
# 注意：值要是已展開的真連線字串，不能留 ${POSTGRES_HOST} 之類的 Zeabur 佔位。
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Auth.js（NextAuth v5）。用 `npx auth secret` 或 `openssl rand -base64 32` 產生。
AUTH_SECRET="請填隨機字串"

# Google OAuth（選填）。未設時登入頁的 Google 鈕會停用，Credentials 仍可用。
# 從 https://console.cloud.google.com 建 OAuth Client，callback 設 <站台>/api/auth/callback/google
GOOGLE_ID=""
GOOGLE_SECRET=""
# 設好上面兩個金鑰後，把這個設成 1，登入/註冊頁的 Google 鈕才會啟用（public flag，不含 secret）。
NEXT_PUBLIC_GOOGLE_ENABLED="0"

# Gemini（AI 助理／側寫生成）。未設時走罐頭退路。
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
